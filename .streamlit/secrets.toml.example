# Copy these values into Streamlit secrets when deploying manually in Streamlit.
# Do not commit real credentials.
STORAGE_BACKEND = "excel"
EXCEL_STORE_PATH = "data/supervisor_control_tower.xlsx"
DATABASE_URL = "postgresql+psycopg2://user:password@host:5432/supervisor_control_tower"
LLM_MODEL = "gpt-5-mini"
MOCK_LLM = true
OPENAI_API_KEY = ""
OPENAI_BASE_URL = ""
AUTH_ENABLED = true
DEMO_AUTH = true
GOOGLE_CLIENT_ID = ""
GOOGLE_CLIENT_SECRET = ""
GOOGLE_REDIRECT_URI = "http://localhost:8501"
APP_ENV = "POC"
LOG_LEVEL = "INFO"
HIGH_CONFIDENCE_THRESHOLD = 0.80
MINIMUM_CONFIDENCE_THRESHOLD = 0.60
