# Storage settings. Use Excel now, switch to PostgreSQL later by changing STORAGE_BACKEND.
STORAGE_BACKEND=excel
EXCEL_STORE_PATH=data/supervisor_control_tower.xlsx

# Keep this for later PostgreSQL migration. It is ignored when STORAGE_BACKEND=excel.
DATABASE_URL=postgresql+psycopg2://supervisor:supervisor@localhost:5432/supervisor_control_tower

# ---- LLM backend priority ----
# 1. AZURE_LLM_ENABLED=true  -> GSK Azure OpenAI via federation token
# 2. OPENAI_API_KEY set       -> Standard OpenAI
# 3. Neither                  -> set MOCK_LLM=true for demos
MOCK_LLM=false

# GSK Azure OpenAI (recommended inside GSK network)
AZURE_LLM_ENABLED=true
AZURE_FEDERATION_URL=https://federation-qa.gsk.com/as/token.oauth2
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
AZURE_ENDPOINT=https://dev.api.gsk.com/co/psc/azureopenai/us6
AZURE_API_VERSION=2025-04-01-preview
AZURE_LLM_MODEL=gpt-5.1
AZURE_SSL_VERIFY=false

# Standard OpenAI (used only when AZURE_LLM_ENABLED=false)
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30

# Authentication settings. DEMO_AUTH=true is recommended for local POC demos.
AUTH_ENABLED=true
DEMO_AUTH=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8501

# App settings
APP_ENV=POC
LOG_LEVEL=INFO
HIGH_CONFIDENCE_THRESHOLD=0.80
MINIMUM_CONFIDENCE_THRESHOLD=0.60
